# MongoDB Atlas — use the hackathon SANDBOX cluster, not personal
MONGODB_URI=mongodb+srv://<user>:<password>@<sandbox-cluster>.mongodb.net/
MONGODB_DB=MediMind
ATLAS_SEARCH_INDEX=skill_index

# Voyage AI (embeddings — voyage-3, 1024 dim)
VOYAGE_API_KEY=

# Fireworks AI (Whisper transcription + code generation)
FIREWORKS_API_KEY=
FIREWORKS_WHISPER_MODEL=whisper-v3
FIREWORKS_CODE_MODEL=accounts/fireworks/models/qwen2p5-coder-32b-instruct

# LiveKit (real-time voice in/out)
# URL must be wss:// (not https://). Browser tokens request agent dispatch using this name:
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM=medimind-ward
LIVEKIT_AGENT_NAME=medimind

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# AWS (Lambda sandbox validator)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_LAMBDA_FUNCTION=MediMind-skill-validator

# LangSmith / LangChain tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=MediMind

# Behaviour tuning
SKILL_MATCH_THRESHOLD=0.78
FORGE_MAX_RETRIES=3
FORGE_PASS_SCORE=0.80
ESCALATE_AFTER_MINUTES=20
